# Fake Currency Detection System - Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# Database Configuration
# =============================================================================
# MySQL (Production):
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/fake_currency_detection

# SQLite (Development/Testing):
# DATABASE_URL=sqlite:///./fake_currency_detection.db

# =============================================================================
# Model Configuration
# =============================================================================
# Path to the trained PyTorch model checkpoint
MODEL_PATH=models/cnn_pytorch_best.pth

# =============================================================================
# API Configuration
# =============================================================================
# Maximum allowed image upload size (bytes) - Default: 10MB
# MAX_BASE64_SIZE=10485760

# Allowed CORS origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Allowed image MIME types (comma-separated)
# ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# =============================================================================
# Server Configuration
# =============================================================================
# Server host address
# HOST=0.0.0.0

# Server port number
# PORT=8000

# =============================================================================
# Notes
# =============================================================================
# - Lines starting with # are comments and won't be loaded
# - Remove # to activate a configuration override
# - Never commit actual .env file to version control
# - For production, use strong database passwords and secure origins
